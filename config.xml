<?xml version="1.0" encoding="UTF-8"?>
<widget xmlns="http://www.w3.org/ns/widgets"
        xmlns:tizen="http://tizen.org/ns/widgets"
        id="https://streamflow.iptv/app"
        version="1.0.0">

  <tizen:application id="StreamFlowIPTV.app"
                     package="StreamFlowI"
                     required_version="4.0" />

  <content src="index.html" />

  <name>StreamFlow IPTV</name>
  <description>Xtream Codes IPTV Client for Samsung Tizen TV</description>

  <icon src="icon.png" />

  <!-- Allow internet access -->
  <access origin="*" subdomains="true" />
  <tizen:allow-navigation>*</tizen:allow-navigation>

  <!-- Required privileges for Tizen 9.0 -->
  <tizen:privilege name="http://developer.samsung.com/privilege/avplay" />
  <tizen:privilege name="http://tizen.org/privilege/internet" />
  <tizen:privilege name="http://tizen.org/privilege/tv.inputdevice" />
  <tizen:privilege name="http://tizen.org/privilege/tv.window" />
  <tizen:privilege name="http://developer.samsung.com/privilege/productinfo" />

  <!-- Tizen TV profile -->
  <tizen:profile name="tv-samsung" />

  <feature name="http://tizen.org/feature/tv.pip" required="false"/>
</widget>
